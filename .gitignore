# ============================================================================
# 📁 ملف .gitignore لمشروع Next.js - إصدار احترافي
# ============================================================================
# يهدف هذا الملف إلى استثناء الملفات والمجلدات التي لا ينبغي رفعها إلى المستودع
# مثل الاعتماديات، ملفات البناء، المتغيرات البيئية، وملفات النظام.

# ============================================================================
# 1️⃣ الاعتماديات (Dependencies)
# ============================================================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ============================================================================
# 2️⃣ ملفات الاختبارات والتقارير (Testing & Coverage)
# ============================================================================
/coverage

# ============================================================================
# 3️⃣ مخرجات البناء (Build Outputs)
# ============================================================================
# Next.js build
/.next/
/out/

# الإنتاج (عام)
/build

# ============================================================================
# 4️⃣ ملفات النظام والمؤقتة (System & Temporary Files)
# ============================================================================
.DS_Store                # ملفات نظام macOS
*.pem                    # مفاتيح خاصة
*.log                    # ملفات السجلات
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================================================
# 5️⃣ المتغيرات البيئية (Environment Variables)
# ============================================================================
# تشمل .env, .env.local, .env.production, إلخ.
.env*

# ============================================================================
# 6️⃣ إعدادات النشر (Deployment)
# ============================================================================
.vercel                  # مجلد إعدادات Vercel

# ============================================================================
# 7️⃣ ملفات TypeScript الإضافية
# ============================================================================
*.tsbuildinfo
next-env.d.ts

# ============================================================================
# 8️⃣ ملفات بيئات التطوير (IDE) - اختيارية
# ============================================================================
# .vscode/
# .idea/
# *.sublime-*

# ============================================================================
# 9️⃣ ملفات مؤقتة أخرى (اختيارية)
# ============================================================================
# *.tmp
# *.temp
# *.swp
# *~
# Thumbs.db